{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_PROJECT_DIR:-.}/.agent-hooks/block-non-pnpm.sh\"",
            "statusMessage": "pnpm 縛りチェック"
          },
          {
            "type": "command",
            "command": "bash \"${CODEX_PROJECT_DIR:-.}/.agent-hooks/block-new-dependency.sh\"",
            "statusMessage": "新規ライブラリ追加チェック"
          },
          {
            "type": "command",
            "command": "bash \"${CODEX_PROJECT_DIR:-.}/.agent-hooks/block-force-push.sh\"",
            "statusMessage": "強制プッシュチェック"
          },
          {
            "type": "command",
            "command": "bash \"${CODEX_PROJECT_DIR:-.}/.agent-hooks/block-main-branch-changes.sh\"",
            "statusMessage": "main ブランチ直接変更チェック"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CODEX_PROJECT_DIR:-.}/.agent-hooks/block-lint-suppress.sh\"",
            "statusMessage": "lint 抑制コメントチェック"
          },
          {
            "type": "command",
            "command": "bash \"${CODEX_PROJECT_DIR:-.}/.agent-hooks/block-new-dependency.sh\"",
            "statusMessage": "新規ライブラリ追加チェック"
          },
          {
            "type": "command",
            "command": "bash \"${CODEX_PROJECT_DIR:-.}/.agent-hooks/block-main-branch-changes.sh\"",
            "statusMessage": "main ブランチ直接変更チェック"
          }
        ]
      }
    ]
  }
}
